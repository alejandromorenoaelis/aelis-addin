<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  IMPORTANTE: reemplaza TODAS las apariciones de
      https://tu-usuario.github.io/aelis-addin
  por la URL real donde alojes estos archivos (p. ej. tu GitHub Pages).
  Puedes hacerlo con un simple buscar-y-reemplazar en el editor.
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>716f87f7-c43a-4c09-848f-1cd99bcca8a7</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Aelis Consulting</ProviderName>
  <DefaultLocale>es-ES</DefaultLocale>
  <DisplayName DefaultValue="Aelis Procesos"/>
  <Description DefaultValue="Botón para lanzar procesos automatizados desde Outlook (Power Automate)."/>
  <IconUrl DefaultValue="https://tu-usuario.github.io/aelis-addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://tu-usuario.github.io/aelis-addin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://tu-usuario.github.io/aelis-addin/"/>

  <AppDomains>
    <AppDomain>https://tu-usuario.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://tu-usuario.github.io/aelis-addin/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="aelisGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="aelisButton">
                  <Label resid="Button.Label"/>
                  <Supertip>
                    <Title resid="Button.Label"/>
                    <Description resid="Button.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16"/>
                    <bt:Image size="32" resid="Icon.32"/>
                    <bt:Image size="80" resid="Icon.80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://tu-usuario.github.io/aelis-addin/assets/icon-16.png"/>
        <bt:Image id="Icon.32" DefaultValue="https://tu-usuario.github.io/aelis-addin/assets/icon-32.png"/>
        <bt:Image id="Icon.80" DefaultValue="https://tu-usuario.github.io/aelis-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://tu-usuario.github.io/aelis-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Aelis"/>
        <bt:String id="Button.Label" DefaultValue="Procesos"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="Button.Tooltip" DefaultValue="Abre el panel para lanzar procesos automatizados con Power Automate."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
