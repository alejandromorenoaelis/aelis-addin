<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>bb4e8c50-aec3-4748-91ff-48c33b0df9dd</Id>
  <Version>1.1.0.0</Version>
  <ProviderName>Aelis Consulting</ProviderName>
  <DefaultLocale>es-ES</DefaultLocale>
  <DisplayName DefaultValue="Aelis Procesos"/>
  <Description DefaultValue="Menú de procesos automatizados desde Outlook con Power Automate."/>
  <IconUrl DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/"/>

  <AppDomains>
    <AppDomain>https://alejandromorenoaelis.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/taskpane.html"/>
        <RequestedHeight>280</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="aelisGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Menu" id="aelisMenu">
                  <Label resid="Menu.Label"/>
                  <Supertip>
                    <Title resid="Menu.Label"/>
                    <Description resid="Menu.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16"/>
                    <bt:Image size="32" resid="Icon.32"/>
                    <bt:Image size="80" resid="Icon.80"/>
                  </Icon>
                  <Items>
                    <Item id="itemRegistrar">
                      <Label resid="Registrar.Label"/>
                      <Supertip>
                        <Title resid="Registrar.Label"/>
                        <Description resid="Registrar.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16"/>
                        <bt:Image size="32" resid="Icon.32"/>
                        <bt:Image size="80" resid="Icon.80"/>
                      </Icon>
                      <Action xsi:type="ShowTaskpane">
                        <SourceLocation resid="Url.Registrar"/>
                      </Action>
                    </Item>
                    <Item id="itemAprobacion">
                      <Label resid="Aprobacion.Label"/>
                      <Supertip>
                        <Title resid="Aprobacion.Label"/>
                        <Description resid="Aprobacion.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16"/>
                        <bt:Image size="32" resid="Icon.32"/>
                        <bt:Image size="80" resid="Icon.80"/>
                      </Icon>
                      <Action xsi:type="ShowTaskpane">
                        <SourceLocation resid="Url.Aprobacion"/>
                      </Action>
                    </Item>
                    <Item id="itemAdjuntos">
                      <Label resid="Adjuntos.Label"/>
                      <Supertip>
                        <Title resid="Adjuntos.Label"/>
                        <Description resid="Adjuntos.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16"/>
                        <bt:Image size="32" resid="Icon.32"/>
                        <bt:Image size="80" resid="Icon.80"/>
                      </Icon>
                      <Action xsi:type="ShowTaskpane">
                        <SourceLocation resid="Url.Adjuntos"/>
                      </Action>
                    </Item>
                    <Item id="itemDocumento">
                      <Label resid="Documento.Label"/>
                      <Supertip>
                        <Title resid="Documento.Label"/>
                        <Description resid="Documento.Tooltip"/>
                      </Supertip>
                      <Icon>
                        <bt:Image size="16" resid="Icon.16"/>
                        <bt:Image size="32" resid="Icon.32"/>
                        <bt:Image size="80" resid="Icon.80"/>
                      </Icon>
                      <Action xsi:type="ShowTaskpane">
                        <SourceLocation resid="Url.Documento"/>
                      </Action>
                    </Item>
                  </Items>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-16.png"/>
        <bt:Image id="Icon.32" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-32.png"/>
        <bt:Image id="Icon.80" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Url.Registrar" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/taskpane.html?action=registrar"/>
        <bt:Url id="Url.Aprobacion" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/taskpane.html?action=aprobacion"/>
        <bt:Url id="Url.Adjuntos" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/taskpane.html?action=adjuntos"/>
        <bt:Url id="Url.Documento" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/taskpane.html?action=documento"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Aelis"/>
        <bt:String id="Menu.Label" DefaultValue="Procesos"/>
        <bt:String id="Registrar.Label" DefaultValue="Registrar correo en seguimiento"/>
        <bt:String id="Aprobacion.Label" DefaultValue="Enviar a aprobación"/>
        <bt:String id="Adjuntos.Label" DefaultValue="Guardar adjuntos en SharePoint"/>
        <bt:String id="Documento.Label" DefaultValue="Generar documento desde plantilla"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="Menu.Tooltip" DefaultValue="Procesos automatizados de Aelis para este correo."/>
        <bt:String id="Registrar.Tooltip" DefaultValue="Guarda remitente, asunto y fecha en la tabla de seguimiento."/>
        <bt:String id="Aprobacion.Tooltip" DefaultValue="Envia el correo a un flujo de aprobacion (proxima fase)."/>
        <bt:String id="Adjuntos.Tooltip" DefaultValue="Archiva los adjuntos en SharePoint (proxima fase)."/>
        <bt:String id="Documento.Tooltip" DefaultValue="Genera un documento desde plantilla (proxima fase)."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
