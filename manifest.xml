<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>8bd89be5-b65f-43e3-89f3-370b35d2afe7</Id>
  <Version>1.3.0.0</Version>
  <ProviderName>Aelis Consulting</ProviderName>
  <DefaultLocale>es-ES</DefaultLocale>
  <DisplayName DefaultValue="Aelis Extraer firma"/>
  <Description DefaultValue="Lee el cuerpo del correo y lo envia a Power Automate para extraer la firma."/>
  <IconUrl DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/"/>

  <AppDomains>
    <AppDomain>https://alejandromorenoaelis.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/taskpane.html"/>
        <RequestedHeight>320</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="aelisGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="aelisFirmaButton">
                  <Label resid="Firma.Label"/>
                  <Supertip>
                    <Title resid="Firma.Label"/>
                    <Description resid="Firma.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16"/>
                    <bt:Image size="32" resid="Icon.32"/>
                    <bt:Image size="80" resid="Icon.80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-16.png"/>
        <bt:Image id="Icon.32" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-32.png"/>
        <bt:Image id="Icon.80" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://alejandromorenoaelis.github.io/aelis-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Aelis"/>
        <bt:String id="Firma.Label" DefaultValue="Extraer firma"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="Firma.Tooltip" DefaultValue="Lee el cuerpo del correo y lo envia a Power Automate para extraer la firma."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
